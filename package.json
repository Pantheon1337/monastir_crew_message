{
  "name": "ruscord-crew",
  "private": true,
  "description": "Клиент (Vite/React) + сервер (Express, SQLite, WebSocket)",
  "scripts": {
    "install:all": "npm --prefix client install && npm --prefix server install",
    "build": "npm --prefix client run build",
    "start": "npm --prefix server run start",
    "import-stickers": "npm --prefix server run import-stickers --",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:reload": "pm2 reload ecosystem.config.cjs",
    "pm2:stop": "pm2 stop monastir-crew"
  }
}
