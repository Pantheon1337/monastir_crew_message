# Скопируйте в .env на сервере или задайте в systemd Environment=.

# Режим: в production сервер отдаёт client/dist и API с одного порта.
NODE_ENV=production

# Порт HTTP + WebSocket (один процесс).
PORT=3001

# Путь к SQLite (по умолчанию server/data/app.db относительно процесса).
# SQLITE_PATH=/var/lib/ruscord-crew/app.db

# Принудительно отдавать SPA (если не хотите выставлять NODE_ENV=production).
# SERVE_SPA=1

# Только если фронт на другом origin: в client при сборке задать VITE_WS_URL=wss://api.example.com/ws
# VITE_WS_URL=

# Если статика открывается с другого хоста/порта, чем API (нет reverse-proxy на /api):
# при сборке client: VITE_API_ORIGIN=https://api.example.com:3001
# VITE_API_ORIGIN=

# Только для локальных/серверных скриптов импорта стикеров (Telegram Bot API).
# Реальное значение — только в .env (не коммитить). При утечке — /revoke в @BotFather.
# Импорт: из каталога server — npm run import-stickers -- Soviet_posters
# TELEGRAM_BOT_TOKEN=

# Сброс кэша иконок чата (client/public/chat-composer/*.png). Увеличивайте после замены файлов.
# VITE_CHAT_COMPOSER_ICONS=1
